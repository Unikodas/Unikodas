# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=https://unikodas.lt

# Server-only — NEVER expose this in client code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stub OTP for development.
# When "true", OTP codes are printed to the server console instead of being sent via SMS.
# Set to "false" (and configure a real SMS provider) before production.
OTP_DEV_MODE=true

# Which SMS provider to use. "stub" prints to console (dev only).
# Future values: "twilio", "vonage". The stub refuses to operate unless
# OTP_DEV_MODE=true, so a misconfigured prod deploy fails loud.
SMS_PROVIDER=stub

# Server-only HMAC pepper used to hash OTP codes before storing them.
# Generate with:  openssl rand -hex 32
# Rotating this value invalidates all live codes (acceptable — they expire in 5 min).
OTP_HMAC_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# CAPTCHA provider. "stub" accepts any token (dev only). Future values:
# "turnstile" (Cloudflare) or "hcaptcha". The stub refuses to operate
# unless CAPTCHA_DEV_MODE=true so a misconfigured prod deploy fails loud.
CAPTCHA_PROVIDER=stub
CAPTCHA_DEV_MODE=true

# When wiring a real CAPTCHA provider, add its credentials here:
# CAPTCHA_TURNSTILE_SITE_KEY=...
# CAPTCHA_TURNSTILE_SECRET_KEY=...

# Email notifications via Resend. Server-only — NEVER expose these with NEXT_PUBLIC_.
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_FROM_EMAIL=Unikodas <pranesimai@unikodas.lt>

# Optional: pin Node env (Next sets this automatically, listed for clarity)
# NODE_ENV=development
